{
    "compilerOptions": {
        "strict": true,
        "module": "CommonJS",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "node",
        "target": "ES2022",
        "lib": [
            "ESNext"
        ],
        "alwaysStrict": true,
        "types": [
            "node"
        ],
        "experimentalDecorators": true,
        "emitDecoratorMetadata": false,
        "skipLibCheck": true,
        "inlineSourceMap": true,
        "inlineSources": true
    },
    "exclude": [
        "node_modules",
        "data",
        "tls"
    ]
}
